# Copy to .env and fill in real values. Never commit .env — it's gitignored.

# Server
PORT=3000

# Claude API (required — meal/plan generation won't work without it)
ANTHROPIC_API_KEY=

# Upstash Redis (required — REST API, no persistent connection needed)
# Get these from the Upstash console: https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin dashboard (required to use /admin and any /api/admin/* endpoint)
ADMIN_KEY=

# Activation codes
DEFAULT_PLAN_LIMIT=10
# Comma-separated legacy codes to migrate into Redis on first use (optional)
ACTIVATION_CODES=

# CORS — your deployed frontend origin (in addition to the hardcoded
# fuelplan.fit/netlify.app allowlist in server.ts)
FRONTEND_URL=http://localhost:5173

# Email recovery (optional — link-email/recover endpoints no-op without these)
RESEND_API_KEY=
FROM_EMAIL="Fuelplan <noreply@fuelplan.fit>"

# Web push notifications (optional — generate a VAPID keypair with
# `npx web-push generate-vapid-keys`)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:support@fuelplan.fit

# LemonSqueezy payments (optional — checkout/webhook endpoints no-op without these)
LS_API_KEY=
LS_STORE_ID=
LS_WEBHOOK_SECRET=
LS_VARIANT_5=
LS_VARIANT_10=
LS_VARIANT_20=
